  "filters": [
    {
      "borderColor": "#ffe669",
      "groupId": "gq",
      "id": "q-r",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/mono-remux.png",
      "isEnabled": true,
      "name": "Remux",
      "pattern": "(?i)remux",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "gq",
      "id": "q-b",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/mono-bluray.png",
      "isEnabled": true,
      "name": "BluRay",
      "pattern": "(?i)^(?=.*(?:bluray|blu-ray|bdrip|brrip|blurip|\\bbd\\b|\\bbr\\b))(?!.*remux)",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#e0917e",
      "groupId": "gq",
      "id": "q-w",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/mono-webdl.png",
      "isEnabled": true,
      "name": "WEB-DL",
      "pattern": "(?i)(?:^|[^a-z0-9])(?:web[-_. ]?dl|webdl|webrip|web-rip|webd|web)(?:$|[^a-z0-9])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "gr",
      "id": "r-4k",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/4k.png",
      "isEnabled": true,
      "name": "4K",
      "pattern": "(?i)^(?=.*(?:2160[pi]?|4k|uhd))(?!.*(?:1080[pi]?|720[pi]?))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "gr",
      "id": "r-1080",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/1080p.png",
      "isEnabled": true,
      "name": "1080p",
      "pattern": "(?i)(?:^|[-_. \\[\\(]|x)1080[pi]?(?:$|[-_. \\]\\)])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#e0917e",
      "groupId": "gr",
      "id": "r-720",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/720p.png",
      "isEnabled": true,
      "name": "720p",
      "pattern": "(?i)(?:^|[-_. \\[\\(]|x)720[pi]?(?:$|[-_. \\]\\)])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "gv",
      "id": "v-hdr10p",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/HDR10Plus.png",
      "isEnabled": true,
      "name": "HDR10+",
      "pattern": "(?i)^(?=.*hdr[\\s._-]?10[\\s._-]?(?:\\\\+|plus|p))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "gv",
      "id": "v-hdr10",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/HDR10.png",
      "isEnabled": true,
      "name": "HDR10",
      "pattern": "(?i)^(?!.*hdr[\\s._-]?10[\\s._-]?(?:\\+|plus|p))(?=.*(?:hdr|(?:^|[^a-z0-9])(?:dv|dovi|dolby[\\s._-]?vision)(?:$|[^a-z0-9])))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "ga",
      "id": "a-at",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_Atmos.png",
      "isEnabled": true,
      "name": "Atmos",
      "pattern": "(?i)(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "ga",
      "id": "a-th",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_TrueHD.png",
      "isEnabled": true,
      "name": "TrueHD",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "ga",
      "id": "a-dp",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_DDPLUS.png",
      "isEnabled": true,
      "name": "DD+",
      "pattern": "(?i)^(?=.*(?:(?:^|[^a-z0-9])ddp|dd\\+|eac-?3|e-?ac-?3))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#e0917e",
      "groupId": "ga",
      "id": "a-dd",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_DD.png",
      "isEnabled": true,
      "name": "DD",
      "pattern": "(?i)^(?=.*(?:(?:^|[^a-z0-9])dd[25][. ][01]|(?:^|[^a-z0-9])dd[^p+a-z]|ac-?3))(?!.*(?:(?:^|[^a-z0-9])ddp|dd\\+|eac-?3|e-?ac-?3))(?!.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "ga",
      "id": "a-dtsx",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/dtsx.png",
      "isEnabled": true,
      "name": "DTS:X",
      "pattern": "(?i)(?:^|[^a-z0-9])dts[-_.: ]?x(?:$|[^a-z0-9])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "ga",
      "id": "a-dtsma",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/dtshdma.png",
      "isEnabled": true,
      "name": "DTS-HD MA",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd[-_. ]?)?ma(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])dts[-_.: ]?x(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "ga",
      "id": "a-dtshd",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/dtshd.png",
      "isEnabled": true,
      "name": "DTS-HD",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])dts[-_. ]?hd)(?!.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd[-_. ]?)?ma)(?!.*(?:^|[^a-z0-9])dts[-_.: ]?x)",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#e0917e",
      "groupId": "ga",
      "id": "a-dts",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/dts.png",
      "isEnabled": true,
      "name": "DTS",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])DTS(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd|ma|xll|x))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#ffe669",
      "groupId": "gc",
      "id": "ch-71",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_71.png",
      "isEnabled": true,
      "name": "7.1",
      "pattern": "(?:^|[^0-9])[7-8][. ][01](?![0-9])",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#a1a1a1",
      "groupId": "gc",
      "id": "ch-51",
      "imageURL": "https://raw.githubusercontent.com/ngreyx1/badges/refs/heads/main/images-white/white_51.png",
      "isEnabled": true,
      "name": "5.1",
      "pattern": "^(?=.*(?:^|[^0-9])5[. ][01](?![0-9]))(?!.*(?:^|[^0-9])[7-8][. ][01](?![0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    }
  ]
}
