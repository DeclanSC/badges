      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#FF858283",
      "groupId": "gi",
      "id": "i-imaxenh",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/imaxenhanced.png",
      "isEnabled": true,
      "name": "IMAX Enhanced",
      "pattern": "(?i)\\bimax[-_. ]?enhanced\\b",
