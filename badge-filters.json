      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtsx",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtsx.png",
