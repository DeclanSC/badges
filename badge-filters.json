      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#FF858283",
      "groupId": "gh",
      "id": "h-hdr10plus",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/hdr10plus.png",
      "isEnabled": true,
      "name": "HDR10+",
      "pattern": "(?i)(?=.*hdr[-_. ]?10(\\+|plus|p))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gh",
      "id": "h-hdr10",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/hdr10.png",
      "isEnabled": true,
      "name": "HDR10",
      "pattern": "(?i)(?=.*hdr[-_. ]?10)(?!.*hdr[-_. ]?10(\\+|plus|p))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
