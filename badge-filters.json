{
  "filters": [
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-r",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-remux.png",
      "isEnabled": true,
      "name": "Remux",
      "pattern": "(?i)remux",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-b",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-bluray.png",
      "isEnabled": true,
      "name": "BluRay",
      "pattern": "(?i)^(?=.*(?:bluray|blu-ray|bdrip|brrip|blurip|\\bbd\\b|\\bbr\\b))(?!.*remux)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-w",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-webdl.png",
      "isEnabled": true,
      "name": "WebDL",
      "pattern": "(?i)(?:^|[^a-z0-9])(?:web[-_. ]?dl|webdl|webrip|web-rip|webd|web)(?:$|[^a-z0-9])",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gr",
      "id": "r-4k",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/4k.png",
      "isEnabled": true,
      "name": "4K",
      "pattern": "(?i)^(?=.*(?:2160[pi]?|4k|uhd))(?!.*(?:1080[pi]?|720[pi]?))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gr",
      "id": "r-1080",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/1080p.png",
      "isEnabled": true,
      "name": "1080p",
      "pattern": "(?i)(?:^|[-_. ]|x)1080[pi]?(?:$|[-_. ])",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gr",
      "id": "r-720",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/720p.png",
      "isEnabled": true,
      "name": "720p",
      "pattern": "(?i)(?:^|[-_. ]|x)720[pi]?(?:$|[-_. ])",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gv",
      "id": "v-hdr10p",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/HDR10Plus.png",
      "isEnabled": true,
      "name": "HDR10+",
      "pattern": "(?i)^(?=.*hdr[\\s._-]?10[\\s._-]?(?:\\\\+|plus|p))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gv",
      "id": "v-hdr10",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/HDR10.png",
      "isEnabled": true,
      "name": "HDR10",
      "pattern": "(?i)^(?=.*hdr)(?!.*hdr[\\s._-]?10[\\s._-]?(?:\\+|plus|p))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gv",
      "id": "v-imax-e",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/IMAX-enhanced.png",
      "isEnabled": true,
      "name": "IMAX Enhanced",
      "pattern": "(?i)(?:^|[^a-z0-9])imax[\\s._-]?enhanced(?:$|[^a-z0-9])",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gv",
      "id": "v-imax",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/IMAX.png",
      "isEnabled": true,
      "name": "IMAX",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])IMAX(?:$|[^a-z0-9]))(?!.*enhanced)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "a-dv",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/vision.png",
      "isEnabled": true,
      "name": "DV",
      "pattern": "(?i)(?:^|[^a-z0-9])(?:dv|dovi|dolby[\\s._-]?vision)(?:$|[^a-z0-9])",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-at",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/atmos.png",
      "isEnabled": true,
      "name": "Atmos",
      "pattern": "(?i)(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9])",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-th",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/truehd.png",
      "isEnabled": true,
      "name": "TrueHD",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dp",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/digitalplus.png",
      "isEnabled": true,
      "name": "DD+",
      "pattern": "(?i)^(?=.*(?:(?:^|[^a-z0-9])ddp|dd\\+|eac-?3|e-?ac-?3))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/digital.png",
      "isEnabled": true,
      "name": "DD",
      "pattern": "(?i)^(?=.*(?:(?:^|[^a-z0-9])dd[25][. ][01]|(?:^|[^a-z0-9])dd[^p+a-z]|ac-?3))(?!.*(?:(?:^|[^a-z0-9])ddp|dd\\+|eac-?3|e-?ac-?3))(?!.*(?:^|[^a-z0-9])true[\\s._-]?hd(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])atmos(?:$|[^a-z0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtsx",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtsx.png",
      "isEnabled": true,
      "name": "DTS:X",
      "pattern": "(?i)(?:^|[^a-z0-9])dts[-_.: ]?x(?:$|[^a-z0-9])",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtsma",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshdma.png",
      "isEnabled": true,
      "name": "DTS-HD MA",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd[-_. ]?)?ma(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])dts[-_.: ]?x(?:$|[^a-z0-9]))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtshd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshd.png",
      "isEnabled": true,
      "name": "DTS-HD",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])dts[-_. ]?hd)(?!.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd[-_. ]?)?ma)(?!.*(?:^|[^a-z0-9])dts[-_.: ]?x)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dts",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dts.png",
      "isEnabled": true,
      "name": "DTS",
      "pattern": "(?i)^(?=.*(?:^|[^a-z0-9])DTS(?:$|[^a-z0-9]))(?!.*(?:^|[^a-z0-9])dts[-_. ]?(?:hd|ma|xll|x))",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gc",
      "id": "ch-71",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/7dot1.png",
      "isEnabled": true,
      "name": "7.1",
      "pattern": "(?:^|[^0-9])[7-8][. ][01](?![0-9])",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gc",
      "id": "ch-51",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/5dot1.png",
      "pattern": "^(?=.*(?:^|[^0-9])5[. ][01](?![0-9]))(?!.*(?:^|[^0-9])[7-8][. ][01](?![0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    }
