{
  "filters": [
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-r",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-remux.png",
      "isEnabled": true,
      "name": "Remux",
      "pattern": "(?i)\\b(?:remux|bd[-_. ]?remux)\\b",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-b",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-bluray.png",
      "isEnabled": true,
      "name": "BluRay",
      "pattern": "(?i)(?=.*\\bblu[-_. ]?ray\\b)(?!.*\\bremux\\b)(?!.*bd[-_. ]?remux)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "gq",
      "id": "q-w",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-webdl.png",
      "isEnabled": true,
      "name": "WebDL",
      "pattern": "(?i)\\b(?:web[-_. ]?dl|webdl|web[-_. ]?rip|webrip)\\b",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#FF858283",
