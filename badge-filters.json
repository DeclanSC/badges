      "pattern": "(?i)(?=.*(?:ddp|dd\\+|eac-?3|e-ac-?3))(?!.*atmos)",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/digital.png",
      "isEnabled": true,
      "name": "DD",
      "pattern": "(?i)(?=.*(?:dd[25][. ]?1|dd[^pa-z]|ac-?3))(?!.*ddp)(?!.*dd\\+)(?!.*eac-?3)(?!.*atmos)",
      "tagColor": "#00000000",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#00000000",
