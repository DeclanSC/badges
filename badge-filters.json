    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtsma",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshdma.png",
      "isEnabled": true,
      "name": "DTS-HD MA",
      "pattern": "(?i)(?=.*\\bdts[-. ]?(?:hd[-. ]?)?ma\\b)(?!.*dts[-.: ]?x)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dtshd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshd.png",
      "isEnabled": true,
      "name": "DTS-HD",
      "pattern": "(?i)(?=.*\\bdts[-_. ]?hd\\b)(?!.*\\bdts[-. ]?(?:hd[-. ]?)?ma\\b)(?!.*dts[-_.: ]?x)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#FF858283",
      "groupId": "ga",
      "id": "a-dts",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dts.png",
      "isEnabled": true,
      "name": "DTS",
      "pattern": "(?i)(?=.*\\bDTS\\b)(?!.*\\bdts[-. ]?(?:hd|ma|xll|x)\\b)",
      "tagColor": "#33FFFFFF",
      "tagStyle": "filled and bordered",
      "textColor": "#FFFFFF",
      "type": "filter"
    },

    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-at",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/atmos.png",
      "isEnabled": true,
      "name": "Atmos",
      "pattern": "(?i)\\batmos\\b",
